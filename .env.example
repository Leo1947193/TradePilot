# PostgreSQL
# For docker compose, keep POSTGRES_HOST=db.
# For running the app directly on the host, change POSTGRES_HOST to 127.0.0.1.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=tradepilot
POSTGRES_PASSWORD=tradepilot
POSTGRES_DB=tradepilot
# Optional explicit DSN override. When set, it takes precedence over the fields above.
# POSTGRES_DSN=postgresql://tradepilot:tradepilot@db:5432/tradepilot
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=10
POSTGRES_CONNECT_TIMEOUT_SECONDS=5.0

# Data providers
MARKET_DATA_PROVIDER=yfinance
NEWS_PROVIDER=finnhub
NEWS_API_KEY=
MACRO_CALENDAR_PATH=
REQUEST_TIMEOUT_SECONDS=8.0

# LLM
LLM_PROVIDER=minimax
LLM_MODEL=minimax-m2.7
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
